{
  "name": "compress-on-input",
  "version": "0.1.0",
  "description": "MCP proxy that compresses bloated tool results before they enter Claude's context window",
  "bin": {
    "compress-on-input": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "claude",
    "context",
    "compression",
    "proxy",
    "claude-code",
    "model-context-protocol",
    "playwright",
    "screenshot",
    "ocr",
    "token-optimization"
  ],
  "files": [
    "dist",
    "src/ocr/vision.swift"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
